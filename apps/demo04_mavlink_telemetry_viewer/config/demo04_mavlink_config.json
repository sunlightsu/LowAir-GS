{
  "telemetry": {
    "source": "mavlink_raw",
    "connection_url": "udp://:14550",
    "vehicle_id": "mavlink_uav_01",
    "read_only": true,
    "auto_reconnect": true
  },
  "geo_origin": {
    "mode": "manual",
    "lat": 30.700000,
    "lon": 104.000000,
    "alt": 500.0
  },
  "scene": {
